<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"

    tools:context=".News_Screen_1">

    <!-- Fixed Header Section -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/top"
        android:textColor="#1D3557"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.058"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/stories"
        android:textColor="#E63946"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/cardView"
        app:layout_constraintHorizontal_bias="0.058"
        app:layout_constraintStart_toEndOf="@+id/textView"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="100dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toStartOf="@+id/cardView"
        app:layout_constraintHorizontal_bias="0.87"
        app:layout_constraintStart_toEndOf="@+id/textView2"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="info"
            android:scaleType="centerCrop"
            android:src="@drawable/info" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="18dp"
        app:cardCornerRadius="100dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.941"
        app:layout_constraintStart_toEndOf="@+id/textView"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="usericon"
            android:scaleType="centerCrop"
            android:src="@drawable/usersicon" />
    </androidx.cardview.widget.CardView>

    <!-- Fixed Search Bar -->
    <EditText
        android:id="@+id/editText2"
        android:layout_width="360dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:autofillHints=""
        android:background="@drawable/rounded_corner"
        android:drawableEnd="@drawable/search_sharp_svgrepo_com"
        android:drawablePadding="8dp"
        android:hint="search_here"
        android:inputType="text"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <!-- Scrollable News Cards Section -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"

        app:layout_constraintBottom_toTopOf="@+id/customBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editText2">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView_cricket"
                android:layout_width="344dp"
                android:layout_height="310dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="194dp"
                    android:contentDescription="image1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/image1" />

                <TextView
                    android:id="@+id/title_cricket"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="200dp"
                    android:textStyle="bold"
                    android:text="inter faculty cricket match\n2025-04-26"
                    android:textSize="16sp" />
                <Button
                    android:id="@+id/readmore1"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="250dp"
                    android:layout_marginStart="200dp"
                    android:backgroundTint="@color/PrimaryBlue"
                    android:text="read more>>"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView_volleyball"
                android:layout_width="344dp"
                android:layout_height="310dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardView_cricket">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="194dp"
                    android:contentDescription="image2"
                    android:scaleType="centerCrop"
                    android:src="@drawable/image2" />

                <TextView
                    android:id="@+id/title_volleyball"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="200dp"
                    android:textStyle="bold"
                    android:text="inter faculty volleyball match\n2025-04-23"
                    android:textSize="16sp" />
                <Button
                    android:id="@+id/readmore2"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="250dp"
                    android:layout_marginStart="200dp"
                    android:backgroundTint="@color/PrimaryBlue"
                    android:text="read more>>"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView_football"
                android:layout_width="344dp"
                android:layout_height="310dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardView_volleyball">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="194dp"
                    android:contentDescription="image3"
                    android:scaleType="centerCrop"
                    android:src="@drawable/image3" />

                <TextView
                    android:id="@+id/title_football"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="200dp"
                    android:text="inter faculty football match\n2025-04-20"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <Button
                    android:id="@+id/readmore3"
                    android:layout_width="130dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="250dp"
                    android:layout_marginStart="200dp"
                    android:backgroundTint="@color/PrimaryBlue"
                    android:text="read more>>"/>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@drawable/navbar_corner"
        android:paddingHorizontal="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Sports Tab -->
        <LinearLayout
            android:id="@+id/nav_sports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background">

            <ImageView
                android:id="@+id/icon_sports"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/tennis_svgrepo_com"
                android:contentDescription="Sports"
                app:tint="@color/nav_text_color" />

            <TextView
                android:id="@+id/label_sports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sports"
                android:textSize="12sp"
                android:textColor="@color/nav_text_color"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Academic Tab -->
        <LinearLayout
            android:id="@+id/nav_academic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background">

            <ImageView
                android:id="@+id/icon_academic"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/academic"
                android:contentDescription="Academic"
                app:tint="@color/nav_text_color" />

            <TextView
                android:id="@+id/label_academic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Academic"
                android:textSize="12sp"
                android:textColor="@color/nav_text_color"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Event Tab -->
        <LinearLayout
            android:id="@+id/nav_event"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_background">

            <ImageView
                android:id="@+id/icon_event"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/event"
                android:contentDescription="Event"
                app:tint="@color/nav_text_color" />

            <TextView
                android:id="@+id/label_event"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event"
                android:textSize="12sp"
                android:textColor="@color/nav_text_color"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>