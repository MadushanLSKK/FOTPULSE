<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".News_Screen_1">


    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="26dp"
        android:text="Top"
        android:textColor="#1D3557"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text=" Stories"
        android:textColor="#E63946"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/textView"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="100dp"
        app:cardElevation="4dp"
        android:layout_marginLeft="150dp"
        app:layout_constraintStart_toEndOf="@id/textView2"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/info_img"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="info"
            android:scaleType="centerCrop"
            android:src="@drawable/info" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        app:cardCornerRadius="100dp"
        app:cardElevation="4dp"
        android:layout_marginRight="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/user_info"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="usericon"
            android:scaleType="centerCrop"
            android:src="@drawable/usersicon" />
    </androidx.cardview.widget.CardView>


    <EditText
        android:id="@+id/editText2"
        android:layout_width="360dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/search_bg"
        android:drawableEnd="@drawable/search_sharp_svgrepo_com"
        android:drawablePadding="8dp"
        android:hint="search here"
        android:inputType="text"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/textView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/newsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:contentDescription="News list"
        app:layout_constraintTop_toBottomOf="@id/editText2"
        app:layout_constraintBottom_toTopOf="@id/customBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@drawable/navbar_corner"
        android:paddingHorizontal="24dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">


        <LinearLayout
            android:id="@+id/nav_sports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_selector">

            <ImageView
                android:id="@+id/icon_sports"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/tennis_svgrepo_com"
                android:contentDescription="Sports" />

            <TextView
                android:id="@+id/label_sports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sports"
                android:textSize="12sp"
                android:textColor="@color/nav_text_color_selector"
                android:layout_marginTop="4dp" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/nav_academic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_selector">

            <ImageView
                android:id="@+id/icon_academic"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/academic"
                android:contentDescription="Academic" />

            <TextView
                android:id="@+id/label_academic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Academic"
                android:textSize="12sp"
                android:textColor="@color/nav_text_color_selector"
                android:layout_marginTop="4dp" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/nav_event"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_item_selector">

            <ImageView
                android:id="@+id/icon_event"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/event"
                android:contentDescription="Event" />

            <TextView
                android:id="@+id/label_event"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event"
                android:textSize="12sp"
                android:textColor="@color/nav_text_color_selector"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
